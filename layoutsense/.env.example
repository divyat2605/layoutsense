# ── Service ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
MAX_UPLOAD_SIZE_MB=50

# ── OCR Pipeline ────────────────────────────────────────────────────────────────
OCR_USE_GPU=false
OCR_LANG=en
OCR_USE_ANGLE_CLS=true
OCR_DET_ALGORITHM=DB
OCR_DET_DB_THRESH=0.3
OCR_DET_DB_BOX_THRESH=0.5
OCR_DET_DB_UNCLIP_RATIO=1.6
OCR_CLS_THRESH=0.9
OCR_REC_ALGORITHM=SVTR_LCNet

# ── Layout Analysis (DBSCAN) ────────────────────────────────────────────────────
DBSCAN_EPS_Y=15.0
DBSCAN_EPS_X=50.0
DBSCAN_MIN_SAMPLES=1
HEADING_HEIGHT_RATIO=1.4
TABLE_ALIGNMENT_TOLERANCE=10.0
FIGURE_MIN_AREA_PX=10000

# ── Supabase / PostgreSQL ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → URI (Transaction mode)
# Replace [project-ref], [password], and [region] with your values.
SUPABASE_DB_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── LayoutLMv3 (optional — needs ~400MB download on first run) ──────────────────
LAYOUTLMV3_ENABLED=false
LAYOUTLMV3_RESCORE_THRESHOLD=0.70
LAYOUTLMV3_CHECKPOINT=nielsr/layoutlmv3-finetuned-publaynet

# ── Redis (optional L1 cache) ────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600
